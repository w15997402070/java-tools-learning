<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE configuration
        PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-config.dtd">
<configuration>
    <!-- 设置日志实现 -->
    <settings>
        <setting name="logImpl" value="SLF4J"/>
        <!-- 开启驼峰命名自动映射（数据库 create_time -> Java createTime） -->
        <setting name="mapUnderscoreToCamelCase" value="true"/>
        <!-- 开启缓存 -->
        <setting name="cacheEnabled" value="true"/>
    </settings>

    <!-- 类型别名 -->
    <typeAliases>
        <package name="com.example.mybatis"/>
    </typeAliases>

    <!-- 环境配置 -->
    <environments default="development">
        <environment id="development">
            <transactionManager type="JDBC"/>
            <dataSource type="POOLED">
                <property name="driver" value="org.h2.Driver"/>
                <property name="url" value="jdbc:h2:mem:testdb;DB_CLOSE_DELAY=-1;MODE=MySQL;INIT=RUNSCRIPT FROM 'classpath:db-init.sql'"/>
                <property name="username" value="sa"/>
                <property name="password" value=""/>
            </dataSource>
        </environment>
    </environments>

    <!-- 映射器注册 -->
    <mappers>
        <!-- 注解方式 Mapper：MyBatis 会自动扫描接口中的注解 -->
        <mapper class="com.example.mybatis.mapper.UserMapper"/>
        <!-- XML 方式 Mapper -->
        <mapper resource="mapper/OrderMapper.xml"/>
    </mappers>
</configuration>
